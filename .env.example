DISCORD_TOKEN=tu_token_del_bot_de_discord
DB_CHANNEL_ID=id_del_canal_donde_se_guardan_los_atletas
LOG_CHANNEL_ID=id_del_canal_logs_sincronizacion
PORT=3000

# Credenciales de acceso (solo en servidor — no van en el navegador)
AUTH_ADMIN_PASS=tu_contraseña_admin
AUTH_SCRUT_PASS=tu_contraseña_escrutador
AUTH_JUDGE_PASS=tu_contraseña_jueces

# Pasos rápidos:
# 1) Cree un canal #base-de-datos en su servidor Discord
# 2) Invite el bot con permisos: Ver canal, Enviar mensajes, Leer historial, Gestionar mensajes
# 3) Copie el ID del canal (clic derecho → Copiar ID) a DB_CHANNEL_ID
# 4) Ejecute: npm run organize-discord
# 5) Ejecute: npm start y abra http://localhost:3000